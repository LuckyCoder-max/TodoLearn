<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TodoLearn.MainPage"
             Title="{Binding Title}">

    <Grid Padding="16" RowDefinitions="Auto, *, Auto" RowSpacing="10">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="8">
            <Entry x:Name="NewTaskEntry"
                   Placeholder="Add a task..."
                   Grid.Column="0" />
            <Button Text="Add"
                    Grid.Column="1"
                    Clicked="OnAddTaskClicked" />
        </Grid>

        <CollectionView Grid.Row="1" 
                        x:Name="TasksCollectionView" 
                        ItemsSource="{Binding DisplayTasks}" 
                        SelectionMode="None" 
                        VerticalOptions="Fill">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnDefinitions="40, *">

                        <Border Grid.Column="0" 
                            WidthRequest="24" 
                            HeightRequest="24" 
                            VerticalOptions="Center" 
                            HorizontalOptions="Center"
                            Padding="0"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="Black"
                                    Offset="0,2"
                                    Radius="5"
                                    Opacity="0.3" />    
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPriorityTapped" NumberOfTapsRequired="1" />
                                <PointerGestureRecognizer PointerEntered="OnPriorityPointerEntered" PointerExited="OnPriorityPointerExited" />
                            </Border.GestureRecognizers>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="Low">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PriorityLowColor}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="Medium">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PriorityMediumColor}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="High">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PriorityHighColor}" />
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>

                        <Grid Grid.Column="1" RowDefinitions="Auto, Auto" RowSpacing="6">
                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <Label Grid.Column="0" 
                                       Text="{Binding Text}" 
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer NumberOfTapsRequired="2" 
                                                               Tapped="OnTaskDoubleTapped" 
                                                               CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Grid Grid.Column="1" RowDefinitions="Auto, Auto" VerticalOptions="Center" Margin="8,0">
                                    <Label Grid.Row="0" Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy HH:mm}'}" FontSize="11" />
                                    <Label Grid.Row="1" Text="{Binding DueAt, StringFormat='Due by: {0:MMM d, yyyy HH:mm}'}" FontSize="11" />
                                </Grid>

                                <Button Grid.Column="2" 
                                        Text="Delete" 
                                        Clicked="OnDeleteClicked" 
                                        CommandParameter="{Binding .}" />
                            </Grid>

                            <Grid Grid.Row="1"
                                  IsVisible="{Binding IsEditing}" 
                                  RowDefinitions="Auto, Auto, Auto" 
                                  RowSpacing="10" 
                                  Padding="0,10,0,0">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, Auto, Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="Priority:" VerticalOptions="Center" />
                                    <Button Grid.Column="1" Text="Low" BackgroundColor="{StaticResource PriorityLowColor}" Clicked="OnPrioritySelectClicked" CommandParameter="0" />
                                    <Button Grid.Column="2" Text="Medium" BackgroundColor="{StaticResource PriorityMediumColor}" Clicked="OnPrioritySelectClicked" CommandParameter="1" />
                                    <Button Grid.Column="3" Text="High" BackgroundColor="{StaticResource PriorityHighColor}" Clicked="OnPrioritySelectClicked" CommandParameter="2" />
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0" 
                                           Text="Due:" 
                                           VerticalOptions="Center" 
                                           WidthRequest="40" />
                                    <DatePicker Grid.Column="1" 
                                        Date="{Binding DueDate, Mode=TwoWay}" 
                                        Format="dd.MM.yyyy"
                                        HorizontalOptions="Start" />
                                    <TimePicker Grid.Column="2" 
                                        Time="{Binding DueTime, Mode=TwoWay}" 
                                        Format="HH:mm"
                                        HorizontalOptions="Start" />
                                </Grid>

                                <Grid Grid.Row="2" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                                    <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked" />
                                    <Button Grid.Column="2" Text="Cancel" Clicked="OnCancelClicked" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" 
                Text="Clear" 
                Clicked="OnClearCompletedClicked" 
                HorizontalOptions="End" />
    </Grid>
</ContentPage>