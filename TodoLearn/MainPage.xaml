<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TodoLearn.MainPage"
             Title="{Binding Title}">
    <StackLayout Padding="16" Spacing="10">
        <StackLayout Orientation="Horizontal" Spacing="8">
            <Entry x:Name="NewTaskEntry" Placeholder="Add a task..." HorizontalOptions="FillAndExpand" />
            <Button Text="Add" Clicked="OnAddTaskClicked" />
        </StackLayout>

        <CollectionView ItemsSource="{Binding Tasks}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="5" Margin="0,4" Padding="10">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Label Text="{Binding Text}" HorizontalOptions="FillAndExpand" />
                            <Label Text="{Binding CreatedAt, StringFormat='{}{0:MMM d}'}" FontSize="12" VerticalOptions="Center" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Clear" Clicked="OnClearCompletedClicked" HorizontalOptions="End" />
    </StackLayout>
</ContentPage>