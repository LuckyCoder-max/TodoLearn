<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TodoLearn.MainPage"
             Title="{Binding Title}"
             BackgroundColor="#F5F5F7">
    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="15">

        <Frame Grid.Row="0" Padding="0" CornerRadius="10" HasShadow="True" BorderColor="Transparent">
            <StackLayout Orientation="Horizontal" Padding="5,0">
                <Entry x:Name="NewTaskEntry" 
                       Placeholder="Что нужно сделать?" 
                       HorizontalOptions="FillAndExpand"
                       Margin="10,0"
                       VerticalOptions="Center"/>
                <Button Text="+" 
                        FontSize="24"
                        FontAttributes="Bold"
                        BackgroundColor="#512BD4"
                        TextColor="White"
                        WidthRequest="50"
                        HeightRequest="50"
                        CornerRadius="25"
                        Clicked="OnAddTaskClicked" 
                        Margin="5"/>
            </StackLayout>
        </Frame>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Tasks}" SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="12" Padding="12" HasShadow="False" BorderColor="#E0E0E0" BackgroundColor="White">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" VerticalOptions="Center">

                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding IsCompleted}" 
                                      VerticalOptions="Center" 
                                      Color="#512BD4"/>

                            <Label Grid.Column="1" 
                                   Text="{Binding Text}" 
                                   VerticalOptions="Center" 
                                   FontSize="16"
                                   TextColor="#333333">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                        <Setter Property="TextColor" Value="#A0A0A0"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Grid.Column="2" 
                                   Text="{Binding DisplayDate}"
                                   FontSize="12"
                                   TextColor="#999999"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" 
                Text="Clear" 
                Clicked="OnClearCompletedClicked" 
                BackgroundColor="Transparent"
                TextColor="Black"
                FontAttributes="Bold"
                HorizontalOptions="Center" />
    </Grid>
</ContentPage>