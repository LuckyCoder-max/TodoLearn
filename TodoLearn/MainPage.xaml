<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TodoLearn.MainPage">

    <Grid ColumnDefinitions="220, *">
        <StackLayout Grid.Column="0" Padding="12" Spacing="8">
            <Label Text="To-Do" FontSize="18" />
            <Button Text="My Day" Clicked="OnFilterClicked" CommandParameter="MyDay" />
            <Button Text="Important" Clicked="OnFilterClicked" CommandParameter="Important" />
            <Button Text="Planned" Clicked="OnFilterClicked" CommandParameter="Planned" />
            <Button Text="All Tasks" Clicked="OnFilterClicked" CommandParameter="All" />
        </StackLayout>

        <StackLayout Grid.Column="1" Padding="16" Spacing="10">
            <Label Text="My Day" FontSize="18" />

            <StackLayout Orientation="Horizontal" Spacing="8">
                <Entry x:Name="NewTaskEntry" Placeholder="Add a task..." HorizontalOptions="FillAndExpand" />
                <Button Text="Add" Clicked="OnAddTaskClicked" />
            </StackLayout>

            <CollectionView x:Name="TasksCollectionView" ItemsSource="{Binding DisplayTasks}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Frame Grid.Column="0" WidthRequest="24" HeightRequest="24" CornerRadius="12" HasShadow="False" VerticalOptions="Center" HorizontalOptions="Center">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPriorityTapped" NumberOfTapsRequired="1" />
                                    <PointerGestureRecognizer PointerEntered="OnPriorityPointerEntered" PointerExited="OnPriorityPointerExited" />
                                </Frame.GestureRecognizers>
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Priority}" Value="Low">
                                        <Setter Property="BackgroundColor" Value="{StaticResource PriorityLowColor}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Priority}" Value="Medium">
                                        <Setter Property="BackgroundColor" Value="{StaticResource PriorityMediumColor}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Priority}" Value="High">
                                        <Setter Property="BackgroundColor" Value="{StaticResource PriorityHighColor}" />
                                    </DataTrigger>
                                </Frame.Triggers>
                            </Frame>

                            <StackLayout Grid.Column="1" Orientation="Vertical" Padding="0" Spacing="6">
                                <StackLayout Orientation="Horizontal" Spacing="8">
                                    <StackLayout.GestureRecognizers>
                                        <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnTaskDoubleTapped" CommandParameter="{Binding .}" />
                                    </StackLayout.GestureRecognizers>

                                    <Label Text="{Binding Text}" HorizontalOptions="FillAndExpand" VerticalOptions="Center" />
                                    <StackLayout VerticalOptions="Center" Spacing="0">
                                        <Label Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy HH:mm}'}" VerticalOptions="Center" Margin="8,0" />
                                        <Label Text="{Binding DueAt, StringFormat='Due by: {0:MMM d, yyyy HH:mm}'}" FontSize="12">
                                        </Label>
                                    </StackLayout>
                                    <Button Text="Edit" Clicked="OnEditClicked" />
                                </StackLayout>

                                <StackLayout Orientation="Vertical" Spacing="6" IsVisible="{Binding IsEditing}">
                                    <StackLayout Orientation="Horizontal" Spacing="8" VerticalOptions="Center">
                                        <Label Text="Priority:" VerticalOptions="Center" />
                                        <Button Text="Low" BackgroundColor="{StaticResource PriorityLowColor}" Clicked="OnPrioritySelectClicked" CommandParameter="0" />
                                        <Button Text="Medium" BackgroundColor="{StaticResource PriorityMediumColor}" Clicked="OnPrioritySelectClicked" CommandParameter="1" />
                                        <Button Text="High" BackgroundColor="{StaticResource PriorityHighColor}" Clicked="OnPrioritySelectClicked" CommandParameter="2" />
                                    </StackLayout>

                                    <StackLayout Orientation="Horizontal" Spacing="8">
                                        <Label Text="Due:" VerticalOptions="Center" />
                                        <DatePicker Date="{Binding DueDate, Mode=TwoWay}" />
                                        <TimePicker Time="{Binding DueTime, Mode=TwoWay}" />
                                    </StackLayout>

                                    <StackLayout Orientation="Horizontal" Spacing="8" HorizontalOptions="End">
                                        <Button Text="Save" Clicked="OnSaveClicked" />
                                        <Button Text="Cancel" Clicked="OnCancelClicked" />
                                    </StackLayout>
                                </StackLayout>
                            </StackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Clear" Clicked="OnClearCompletedClicked" HorizontalOptions="End" />
        </StackLayout>
    </Grid>

</ContentPage>
